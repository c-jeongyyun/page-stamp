{
  "name": "page-stamp",
  "version": "1.0.0",
  "description": "Figma plugin - Page Stamp",
  "type": "module",
  "scripts": {
    "build": "pnpm typecheck && node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --deny-warnings",
    "lint:fix": "oxlint src --fix --deny-warnings",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "test": "vitest run",
    "prepare": "husky",
    "branch": "tsx scripts/create-branch.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@figma/plugin-typings": "^1.104.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/preact": "^8.6.18",
    "@storybook/preact-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.3",
    "msw": "^2.14.5",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "rolldown": "^1.0.0",
    "storybook": "^8.6.18",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix --deny-warnings --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{json,html,css,md}": "oxfmt --no-error-on-unmatched-pattern"
  }
}
